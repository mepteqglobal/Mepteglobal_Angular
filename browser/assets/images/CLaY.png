make\"},{\"title\":\"Use Brandfetch with n8n\",\"sidebarTitle\":\"n8n\",\"description\":null,\"href\":\"/integrations/n8n\"}]},{\"group\":\"Delivery methods\",\"pages\":[{\"title\":\"Data ingestion \u0026 operationalization\",\"sidebarTitle\":\"Data Ingestion\",\"description\":null,\"href\":\"/delivery-methods/data-ingestion\"},{\"group\":\"Webhooks\",\"pages\":[{\"title\":\"Overview\",\"description\":\"Get notified of changes by receiving events at your webhook URL.\",\"href\":\"/delivery-methods/webhooks/overview\"},{\"title\":\"Setup a webhook\",\"description\":\"Start receiving event payloads\",\"href\":\"/delivery-methods/webhooks/setup\"},{\"title\":\"Delivery behaviors\",\"description\":\"This section helps you understand different behaviors to expect regarding how Brandfetch sends events to your webhook endpoint.\",\"href\":\"/delivery-methods/webhooks/delivery-behaviors\"},{\"title\":\"Best practices\",\"description\":\"Review these best practices to make sure your webhooks remain secure and function well with your integration.\",\"href\":\"/delivery-methods/webhooks/best-practices\"},{\"title\":\"Event types\",\"description\":\"Overview of subscribable event types\",\"href\":\"/delivery-methods/webhooks/event-types\"}]},{\"title\":\"GraphQL\",\"description\":null,\"href\":\"/delivery-methods/graphql\"}]},{\"group\":\"Support\",\"pages\":[{\"title\":\"Getting help\",\"description\":\"Our support team is always available and willing to assist you.\",\"href\":\"/support/getting-help\"},{\"title\":\"Security \u0026 SOC2\",\"description\":\"Our commitment to secure data handling and best-in-class practices.\",\"href\":\"/support/security-soc2\"},{\"title\":\"Report inaccuracies\",\"url\":\"https://brandfetch.com/update?mode=dev\",\"description\":\"Report incorrect or missing brand info.\",\"href\":\"/support/report-inaccuracies\"},{\"title\":\"Terms and Conditions\",\"url\":\"https://brandfetch.com/terms?mode=dev\",\"description\":null,\"href\":\"/support/terms-and-conditions\"},{\"title\":\"Service status\",\"url\":\"https://status.brandfetch.io\",\"description\":\"Check the status of Brandfetch services.\",\"href\":\"/support/service-status\"}]}]},{\"tab\":\"API References\",\"groups\":[{\"group\":\"Brand API\",\"pages\":[{\"title\":\"Brand API by domain\",\"sidebarTitle\":\"/v2/brands/domain/{domain}\",\"openapi\":\"GET /v2/brands/domain/{domain}\",\"description\":\"Get brand data using a domain name\",\"href\":\"/reference/brand-api-domain\"},{\"title\":\"Brand API by ticker\",\"sidebarTitle\":\"/v2/brands/ticker/{ticker}\",\"openapi\":\"GET /v2/brands/ticker/{ticker}\",\"description\":\"Get brand data using a Stock or ETF ticker\",\"href\":\"/reference/brand-api-ticker\"},{\"title\":\"Brand API by ISIN\",\"sidebarTitle\":\"/v2/brands/isin/{isin}\",\"openapi\":\"GET /v2/brands/isin/{isin}\",\"description\":\"Get brand data using an ISIN code\",\"href\":\"/reference/brand-api-isin\"},{\"title\":\"Brand API by crypto\",\"sidebarTitle\":\"/v2/brands/crypto/{symbol}\",\"openapi\":\"GET /v2/brands/crypto/{symbol}\",\"description\":\"Get brand data using a crypto symbol\",\"href\":\"/reference/brand-api-crypto\"},{\"title\":\"Brand API (auto-detect)\",\"sidebarTitle\":\"/v2/brands/{identifier}\",\"openapi\":\"GET /v2/brands/{identifier}\",\"description\":\"Get brand data using a Domain, Brand ID, ISIN, Stock/ETF ticker, or Crypto symbol\",\"href\":\"/reference/brand-api\"}]},{\"group\":\"Brand Context API\",\"pages\":[{\"title\":\"Brand Context API\",\"sidebarTitle\":\"/v2/context/{domain}\",\"openapi\":\"GET /v2/context/{domain}\",\"description\":\"Get a structured, narrative-rich brand context for a domain — including identity, positioning, voice, and visual style.\",\"href\":\"/reference/brand-context-api\"}]},{\"group\":\"Brand Search API\",\"pages\":[{\"title\":\"Brand Search API\",\"sidebarTitle\":\"/v2/search/{name}\",\"openapi\":\"GET /v2/search/{name}?c={clientId}\",\"description\":\"Search for brands by name, logi